# ==========================================
# XeBuonHo - Environment Variables
# Copy to .env and update values
# ==========================================

# === Service Ports ===
HTTP_PORT=8080
GRPC_PORT=50051

# === Database (PostgreSQL + PostGIS) ===
DATABASE_URL=postgresql://app:secret@localhost:5432/xebuonho?sslmode=disable

# === Redis ===
REDIS_URL=localhost:6379

# === Apache Kafka ===
KAFKA_BROKERS=localhost:9092

# === MQTT (EMQX) ===
MQTT_BROKER=tcp://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=

# === Authentication ===
JWT_SECRET=dev-secret-change-me-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# === Maps API (Goong) ===
GOONG_API_KEY=your-goong-api-key
GOONG_BASE_URL=https://rsapi.goong.io

# === Maps API (Mapbox - fallback) ===
MAPBOX_ACCESS_TOKEN=your-mapbox-token

# === SMS Gateway ===
SMS_PROVIDER=twilio
SMS_API_KEY=
SMS_FROM_NUMBER=

# === Payment ===
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
ZALOPAY_APP_ID=
ZALOPAY_KEY1=
ZALOPAY_KEY2=

# === Service Discovery (Internal gRPC) ===
MATCHING_SERVICE=localhost:50055
LOCATION_SERVICE=localhost:50056
PAYMENT_SERVICE=localhost:50054
MERCHANT_SERVICE=localhost:50059
ORDER_SERVICE=localhost:50058
DRIVER_SERVICE=localhost:50052

# === Logging ===
LOG_LEVEL=info
LOG_FORMAT=json

# === Feature Flags ===
ENABLE_SURGE_PRICING=true
SURGE_MAX_MULTIPLIER=2.5
ENABLE_FOOD_DELIVERY=true
ENABLE_GROCERY=true
ENABLE_DESIGNATED_DRIVER=true
