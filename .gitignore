# ==========================================
# Go Backend
# ==========================================

# Binaries
*.exe
*.exe~
*.dll
*.so
*.dylib
/bin/
/build/

# Go build & test
*.test
*.out
vendor/

# Go workspace
go.work.sum

# ==========================================
# Flutter / Dart
# ==========================================

# Dart tool
.dart_tool/

# Flutter build outputs
**/build/
**/android/.gradle/
**/android/app/debug/
**/android/app/profile/
**/android/app/release/

# Flutter generated
.flutter-plugins
.flutter-plugins-dependencies
*.iml
.metadata

# pubspec.lock (not needed for apps, only libraries)
apps/**/pubspec.lock

# Flutter web generated
apps/rider/web/.last_build_id

# ==========================================
# iOS (generated by Flutter/Xcode)
# ==========================================
**/ios/Pods/
**/ios/.symlinks/
**/ios/Flutter/Flutter.framework
**/ios/Flutter/Flutter.podspec
**/ios/Flutter/Generated.xcconfig
**/ios/Flutter/app.flx
**/ios/Flutter/app.zip
**/ios/Flutter/engine/
**/ios/Flutter/flutter_export_environment.sh
**/ios/ServiceDefinitions.json
**/ios/Runner/GeneratedPluginRegistrant.*

# ==========================================
# Android (generated)
# ==========================================
**/android/app/src/main/java/io/flutter/plugins/GeneratedPluginRegistrant.java
**/android/key.properties
**/android/*.keystore
**/android/*.jks
**/android/local.properties

